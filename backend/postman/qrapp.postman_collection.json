{
  "info": {
    "name": "qrapp",
    "_postman_id": "b4f2c8d3-qrapp-collection",
    "description": "Postman collection for qrapp backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Compute base64 Basic auth from adminUsername/adminPassword and store in adminAuth",
          "var user = pm.environment.get('adminUsername') || '';",
          "var pass = pm.environment.get('adminPassword') || '';",
          "if (user !== null && pass !== null) {",
          "    try {",
          "        pm.environment.set('adminAuth', btoa(user + ':' + pass));",
          "    } catch (e) {",
          "        // btoa might not be present in some runtimes; fallback to manual encode",
          "        pm.environment.set('adminAuth', Buffer.from(user + ':' + pass).toString('base64'));",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Admin - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {"raw": "{{baseUrl}}/admin/login", "host": ["{{baseUrl}}"], "path": ["admin","login"]}
      },
      "response": []
    },
    {
      "name": "Get Menu",
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "{{baseUrl}}/menu", "host": ["{{baseUrl}}"], "path": ["menu"]}
      },
      "response": []
    },
    {
      "name": "Add Menu Item (admin)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Basic {{adminAuth}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Classic Burger\",\n  \"price\": 6.99,\n  \"category\": \"Mains\",\n  \"available\": true,\n  \"description\": \"Beef burger with cheese\",\n  \"imageUrl\": \"https://example.com/image.jpg\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {"raw": "{{baseUrl}}/menu", "host": ["{{baseUrl}}"], "path": ["menu"]}
      },
      "response": []
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+1234567890\",\n  \"items\": [\n    { \"itemId\": 1, \"quantity\": 2 }\n  ]\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {"raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"]}
      },
      "response": []
    },
    {
      "name": "Webhook - Razorpay",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-Razorpay-Signature", "value": "{{webhookSignature}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"entity\": \"event\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"razorpay_order_id\": \"order_ABC123\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {"raw": "{{baseUrl}}/webhook/razorpay", "host": ["{{baseUrl}}"], "path": ["webhook","razorpay"]}
      },
      "response": []
    },
    {
      "name": "Update Order Status (admin)",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Basic {{adminAuth}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PAID\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {"raw": "{{baseUrl}}/admin/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["admin","orders","{{orderId}}","status"]}
      },
      "response": []
    },
    {
      "name": "List Orders (admin)",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Basic {{adminAuth}}"}
        ],
        "url": {"raw": "{{baseUrl}}/admin/orders", "host": ["{{baseUrl}}"], "path": ["admin","orders"]}
      },
      "response": []
    }
  ]
}

